{
  "name": "mcp-switchboard",
  "version": "0.1.0",
  "description": "Local-first governed MCP aggregator — connect every MCP server to your agent through one endpoint, with on/off toggles, read/write/full scopes, an encrypted local credential vault, and an audit log. A free, self-hosted alternative to hosted tool routers.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "MAS-AI Technologies",
  "mcpName": "io.github.Mas-AI-Official/mcp-switchboard",
  "homepage": "https://github.com/Mas-AI-Official/mcp-switchboard#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mas-AI-Official/mcp-switchboard.git"
  },
  "bugs": {
    "url": "https://github.com/Mas-AI-Official/mcp-switchboard/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "aggregator",
    "gateway",
    "proxy",
    "ai",
    "agents",
    "claude",
    "cursor",
    "llm-tools",
    "governance",
    "local-first",
    "self-hosted",
    "composio-alternative"
  ],
  "bin": {
    "switchboard": "dist/cli.js",
    "mcp-switchboard": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "public",
    "data",
    "server.json",
    "switchboard.config.example.yaml",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "serve": "node dist/cli.js serve",
    "security:audit": "npm audit --audit-level=low",
    "verify:oauth": "node scripts/verify-oauth.mjs",
    "verify:webhook": "node scripts/verify-webhook.mjs",
    "verify:triggers": "node scripts/verify-triggers.mjs",
    "verify:modifiers": "node scripts/verify-modifiers.mjs",
    "verify:httptool": "node scripts/verify-httptool.mjs",
    "verify:openapi": "node scripts/verify-openapi.mjs",
    "verify:auth": "node scripts/verify-auth.mjs",
    "verify:council": "node scripts/verify-council.mjs",
    "verify:catalog": "node scripts/verify-catalog.mjs",
    "verify:registry": "node scripts/verify-registry-metadata.mjs",
    "verify:search": "node scripts/verify-search.mjs",
    "verify:install": "node scripts/verify-install.mjs",
    "verify:local-llm": "node scripts/verify-local-llm.mjs",
    "verify:dashboard": "node scripts/verify-dashboard.mjs",
    "verify:profiles": "node scripts/verify-profiles.mjs",
    "verify:limits": "node scripts/verify-limits.mjs",
    "verify:breaker": "node scripts/verify-breaker.mjs",
    "verify:config": "node scripts/verify-config.mjs",
    "verify:audit": "node scripts/verify-audit.mjs",
    "verify:resources-prompts": "node scripts/verify-resources-prompts.mjs",
    "verify:health": "node scripts/verify-health.mjs",
    "verify:retry": "node scripts/verify-retry.mjs",
    "verify:doctor": "node scripts/verify-doctor.mjs",
    "verify:vault": "node scripts/verify-vault.mjs",
    "verify:router": "node scripts/verify-router.mjs",
    "verify:expose": "node scripts/verify-expose.mjs",
    "smoke:codex": "node scripts/smoke-codex-switchboard.mjs",
    "verify": "npm run build && npm run security:audit && npm run verify:oauth && npm run verify:webhook && npm run verify:triggers && npm run verify:modifiers && npm run verify:httptool && npm run verify:auth && npm run verify:council && npm run verify:catalog && npm run verify:registry && npm run verify:search && npm run verify:install && npm run verify:local-llm && npm run verify:dashboard && npm run verify:profiles && npm run verify:limits && npm run verify:breaker && npm run verify:config && npm run verify:audit && npm run verify:resources-prompts && npm run verify:health && npm run verify:retry && npm run verify:doctor && npm run verify:vault && npm run verify:router && npm run verify:openapi && npm run verify:expose",
    "prepublishOnly": "npm run verify"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "commander": "15.0.0",
    "express": "5.2.1",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/express": "5.0.5",
    "@types/node": "22.10.5",
    "typescript": "5.7.3"
  }
}
